#!/bin/bash

# xssh - SSH 快速连接管理器
# 完全兼容 SSH config 格式，与 VSCode Remote SSH 兼容
# 使用方法: xssh [服务器名称]

CONFIG_FILE="$HOME/.ssh/config"

# ============================================================================
# 辅助函数
# ============================================================================

# 显示帮助信息
show_help() {
    cat << EOF
xssh - SSH 快速连接管理器

用法:
  xssh [Host别名]            # 连接到指定服务器
  xssh -l, --list            # 列出所有可用服务器
  xssh -a, --add             # 添加新服务器
  xssh -e, --edit            # 编辑配置文件
  xssh -c, --copy            # 复制Host别名到剪贴板
  xssh -v, --verify          # 验证配置文件
  xssh -i, --info            # 显示配置信息
  xssh -h, --help            # 显示帮助信息

特点:
  • 完全兼容 SSH config 格式
  • 与 VSCode Remote SSH 共用同一配置
  • 标准 SSH 命令行工具兼容

示例:
  xssh web-server-1          # 连接到 web-server-1
  xssh -l                    # 列出所有服务器
  xssh -a                    # 添加新服务器
  xssh -c web-server-1       # 复制连接命令

EOF
}

# 检查配置文件是否存在
check_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        mkdir -p "$(dirname "$CONFIG_FILE")"
        touch "$CONFIG_FILE"
        chmod 600 "$CONFIG_FILE"
        echo "✓ 已创建 SSH 配置文件: $CONFIG_FILE"
    fi
    return 0
}

# 从 SSH config 中解析所有 Host
get_hosts() {
    check_config
    grep -E "^Host\s+" "$CONFIG_FILE" | awk '{print $2}' | grep -v '\*'
}

# 解析特定 Host 的配置
parse_host_config() {
    local host=$1
    local in_host=0
    local hostname user port identity_file strict_check
    
    while IFS= read -r line; do
        # 移除行首尾空格
        line=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        
        # 跳过注释和空行
        [[ "$line" =~ ^# ]] && continue
        [[ -z "$line" ]] && continue
        
        # 检查是否是新的 Host 块
        if [[ "$line" =~ ^Host[[:space:]]+ ]]; then
            if [[ $in_host -eq 1 ]]; then
                # 已经离开目标 Host
                break
            fi
            local check_host=$(echo "$line" | awk '{print $2}')
            if [[ "$check_host" == "$host" ]]; then
                in_host=1
            fi
            continue
        fi
        
        # 只处理目标 Host 内的配置
        if [[ $in_host -eq 1 ]]; then
            local key=$(echo "$line" | awk '{print $1}')
            local value=$(echo "$line" | awk '{$1=""; print $0}' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            
            case "$key" in
                HostName) hostname="$value" ;;
                User) user="$value" ;;
                Port) port="$value" ;;
                IdentityFile) identity_file="$value" ;;
                StrictHostKeyChecking) strict_check="$value" ;;
            esac
        fi
    done < "$CONFIG_FILE"
    
    # 验证必需的配置
    if [[ -z "$hostname" ]]; then
        echo "错误: 找不到 Host '$host' 或 HostName 未配置" >&2
        return 1
    fi
    
    # 设置默认值
    : ${port:=22}
    : ${user:=$USER}
    
    echo "$hostname|$port|$user|$identity_file|$strict_check"
}

# 列出所有服务器
list_servers() {
    check_config
    
    local hosts=$(get_hosts)
    if [[ -z "$hosts" ]]; then
        echo "没有配置任何 Host"
        return 0
    fi
    
    echo "可用的服务器:"
    echo "────────────────────────────────────────────────────────"
    printf "  %-20s  %s@%s:%s\n" "Host别名" "用户" "主机" "端口"
    echo "────────────────────────────────────────────────────────"
    
    while IFS= read -r host; do
        local config=$(parse_host_config "$host")
        if [[ $? -eq 0 ]]; then
            local hostname=$(echo "$config" | cut -d'|' -f1)
            local port=$(echo "$config" | cut -d'|' -f2)
            local user=$(echo "$config" | cut -d'|' -f3)
            printf "  %-20s  %s@%s:%s\n" "$host" "$user" "$hostname" "$port"
        fi
    done <<< "$hosts"
    echo "────────────────────────────────────────────────────────"
}

# 添加新服务器（交互式）
add_server() {
    check_config
    
    echo "添加新 Host"
    read -p "Host 别名 (如: web-server-1): " host_alias
    
    if [[ -z "$host_alias" ]]; then
        echo "错误: Host 别名不能为空" >&2
        return 1
    fi
    
    # 检查是否已存在
    if grep -q "^Host[[:space:]]\+$host_alias\$" "$CONFIG_FILE"; then
        echo "错误: Host '$host_alias' 已存在" >&2
        return 1
    fi
    
    read -p "主机名/IP (HostName): " hostname
    read -p "用户名 (User, 默认 $USER): " user
    read -p "端口 (Port, 默认 22): " port
    read -p "私钥路径 (IdentityFile, 可选): " identity_file
    
    # 设置默认值
    : ${user:=$USER}
    : ${port:=22}
    
    # 追加到配置文件
    {
        echo ""
        echo "Host $host_alias"
        echo "    HostName $hostname"
        echo "    User $user"
        echo "    Port $port"
        [[ -n "$identity_file" ]] && echo "    IdentityFile $identity_file"
    } >> "$CONFIG_FILE"
    
    chmod 600 "$CONFIG_FILE"
    echo "✓ Host '$host_alias' 已添加"
    echo "提示: 现在可以用 'xssh $host_alias' 连接"
}

# 编辑配置文件
edit_config() {
    check_config
    
    echo "正在打开 SSH 配置文件..."
    ${EDITOR:-vim} "$CONFIG_FILE"
    
    # 确保权限正确
    chmod 600 "$CONFIG_FILE"
}

# 复制连接命令到剪贴板
copy_to_clipboard() {
    local host=$1
    
    if ! parse_host_config "$host" > /dev/null 2>&1; then
        return 1
    fi
    
    local cmd="ssh $host"
    
    # 检查剪贴板工具可用性
    if command -v xclip &> /dev/null; then
        echo "$cmd" | xclip -selection clipboard
        echo "✓ 已复制到剪贴板: $cmd"
    elif command -v xsel &> /dev/null; then
        echo "$cmd" | xsel --clipboard
        echo "✓ 已复制到剪贴板: $cmd"
    elif command -v pbcopy &> /dev/null; then
        echo "$cmd" | pbcopy
        echo "✓ 已复制到剪贴板: $cmd"
    else
        echo "剪贴板不可用，连接命令: $cmd"
    fi
}

# 连接到服务器
connect_server() {
    local host=$1
    
    local config=$(parse_host_config "$host" 2>&1)
    if [[ $? -ne 0 ]]; then
        echo "$config" >&2
        echo "可用的 Host:" >&2
        list_servers >&2
        return 1
    fi
    
    local hostname=$(echo "$config" | cut -d'|' -f1)
    local port=$(echo "$config" | cut -d'|' -f2)
    local user=$(echo "$config" | cut -d'|' -f3)
    
    echo "正在连接..." >&2
    echo "Host: $host (${user}@${hostname}:${port})" >&2
    echo "" >&2
    
    # 使用 SSH 连接，让 SSH 读取配置文件处理所有细节
    ssh "$host"
}

# 验证配置文件格式
verify_config() {
    check_config
    
    local hosts=$(get_hosts)
    if [[ -z "$hosts" ]]; then
        echo "配置文件为空，还没有定义任何 Host"
        return 0
    fi
    
    echo "验证 SSH 配置..."
    
    local error_count=0
    while IFS= read -r host; do
        if ! parse_host_config "$host" > /dev/null 2>&1; then
            echo "✗ Host '$host' 配置不完整"
            ((error_count++))
        else
            local config=$(parse_host_config "$host")
            local hostname=$(echo "$config" | cut -d'|' -f1)
            local identity_file=$(echo "$config" | cut -d'|' -f4)
            
            echo -n "✓ $host: "
            
            # 检查私钥文件
            if [[ -n "$identity_file" ]]; then
                identity_file="${identity_file/#\~/$HOME}"
                if [[ -f "$identity_file" ]]; then
                    echo "OK (私钥存在)"
                else
                    echo "警告: 私钥不存在 ($identity_file)"
                    ((error_count++))
                fi
            else
                echo "OK"
            fi
        fi
    done <<< "$hosts"
    
    if [[ $error_count -eq 0 ]]; then
        echo "✓ 配置验证通过"
    else
        echo "✗ 发现 $error_count 个问题"
        return 1
    fi
}

# 显示配置文件信息
show_info() {
    echo "SSH 配置信息"
    echo "─────────────────────────────────"
    echo "配置文件: $CONFIG_FILE"
    
    if [[ -f "$CONFIG_FILE" ]]; then
        local perms=$(stat -c '%A' "$CONFIG_FILE" 2>/dev/null || stat -f '%OLp' "$CONFIG_FILE" 2>/dev/null)
        echo "权限: $perms"
        local count=$(get_hosts | wc -l)
        echo "已配置 Host 数: $count"
    else
        echo "状态: 文件不存在"
    fi
    
    echo "─────────────────────────────────"
}

# ============================================================================
# 主程序
# ============================================================================

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        return 0
    fi
    
    case "$1" in
        -h|--help)
            show_help
            ;;
        -l|--list)
            list_servers
            ;;
        -a|--add)
            add_server
            ;;
        -e|--edit)
            edit_config
            ;;
        -c|--copy)
            if [[ -z "$2" ]]; then
                echo "错误: 请指定 Host 别名" >&2
                echo "用法: xssh -c <Host别名>" >&2
                return 1
            fi
            copy_to_clipboard "$2"
            ;;
        -v|--verify)
            verify_config
            ;;
        -i|--info)
            show_info
            ;;
        *)
            connect_server "$1"
            ;;
    esac
}

main "$@"

